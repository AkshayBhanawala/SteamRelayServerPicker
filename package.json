{
	"name": "cs2-ping-dashboard",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"main": "dist-electron/main.js",
	"scripts": {
		"dev:web": "vite --mode web",
		"dev:electron": "vite --mode electron",
		"build": "vue-tsc && vite build --mode electron && electron-builder",
		"preview": "vite preview"
	},
	"build": {
		"appId": "com.th3az.cs2ping",
		"productName": "CS2 Ping Dashboard",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/**/*"
		],
		"win": {
			"target": [
				"portable"
			]
		},
		"mac": {
			"target": [
				"dmg"
			]
		},
		"linux": {
			"target": [
				"AppImage"
			]
		}
	},
	"dependencies": {
		"@vscode/sudo-prompt": "^9.3.2",
		"ping": "^1.0.0",
		"vue": "^3.5.39"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"@types/ping": "^0.4.4",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/tsconfig": "^0.9.1",
		"electron": "^43.1.0",
		"electron-builder": "^26.15.3",
		"electron-ipc-logger": "^1.2.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.9.2",
		"prettier": "3.9.5",
		"typescript": "~6.0.2",
		"vite": "^8.1.1",
		"vite-plugin-electron": "^1.1.0",
		"vite-plugin-electron-renderer": "^1.0.0",
		"vue-tsc": "^3.3.5"
	}
}